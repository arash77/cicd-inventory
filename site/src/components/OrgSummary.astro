---
interface Props {
  org: string;
  repoCount: number;
  workflowCount: number;
  href: string;
  searchText?: string;
}

const { org, repoCount, workflowCount, href, searchText } = Astro.props;
const avatarUrl = `https://github.com/${org}.png?size=80`;
---

<a
  href={href}
  aria-label={`View ${org} organization – ${repoCount} repos, ${workflowCount} workflows`}
  class="group flex items-center gap-4 bg-white rounded-xl border border-slate-200 p-5 cursor-pointer hover:border-blue-400 hover:shadow-md hover:shadow-blue-100/50 transition-all duration-200"
  data-search-text={searchText?.toLowerCase() ?? org.toLowerCase()}
>
  <img
    src={avatarUrl}
    alt={`${org} avatar`}
    width="48"
    height="48"
    class="rounded-full border border-slate-200 group-hover:border-blue-300 transition-colors duration-200"
    loading="lazy"
  />
  <div class="min-w-0">
    <h3 class="font-semibold text-slate-900 truncate group-hover:text-blue-600 transition-colors duration-150">{org}</h3>
    <p class="text-sm text-slate-500">
      {repoCount} repo{repoCount !== 1 ? 's' : ''} &middot; {workflowCount} workflow{workflowCount !== 1 ? 's' : ''}
    </p>
  </div>
  <svg
    class="ml-auto text-slate-300 shrink-0 group-hover:text-blue-400 group-hover:translate-x-0.5 transition-all duration-200"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="9 18 15 12 9 6" />
  </svg>
</a>
