---
interface Props {
  src: string;
  alt?: string;
  workflowUrl?: string;
}

const { src, alt = 'Build status', workflowUrl } = Astro.props;
---

{workflowUrl ? (
  <a
    href={workflowUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${alt} – opens in new tab`}
    title={alt}
    dir="ltr"
    class="inline-flex items-center cursor-pointer rounded transition-opacity duration-150 hover:opacity-80"
  >
    <img src={src} alt={alt} loading="lazy" width="220" height="20" class="h-5 w-auto block" />
  </a>
) : (
  <img src={src} alt={alt} loading="lazy" width="220" height="20" class="h-5 w-auto block" />
)}
