---
interface Props {
  src: string;
  alt?: string;
  workflowUrl?: string;
}

const { src, alt = 'Build status', workflowUrl } = Astro.props;
---

{workflowUrl ? (
  <a href={workflowUrl} target="_blank" rel="noopener noreferrer" title={alt}>
    <img src={src} alt={alt} loading="lazy" class="h-5 inline-block" />
  </a>
) : (
  <img src={src} alt={alt} loading="lazy" class="h-5 inline-block" />
)}
