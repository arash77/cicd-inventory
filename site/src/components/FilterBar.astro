---
interface Props {
  orgs?: string[];
  triggers?: string[];
  repos?: string[];
  statuses?: string[];
  reposByOrg?: Record<string, string[]>;
  showOrgFilter?: boolean;
  placeholder?: string;
  pageSize?: number;
}

const {
  orgs = [],
  triggers = [],
  repos = [],
  statuses = [],
  reposByOrg = {},
  showOrgFilter = false,
  placeholder = 'Search workflows, repos, orgs, actions…',
  pageSize,
} = Astro.props;

function formatStatus(s: string): string {
  return s.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

const chevron = `<svg class="pointer-events-none absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>`;
const selectClass = 'appearance-none w-full sm:w-auto py-2.5 pl-3 pr-8 rounded-lg border border-slate-300 bg-white text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow duration-150 cursor-pointer text-slate-700';
---

<div class="mb-6 rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden" role="search" aria-label="Filter workflows">

  <!-- Row 1: Search -->
  <div class="p-4 bg-slate-50/50 border-b border-slate-100">
    <div class="relative">
      <label for="search-input" class="sr-only">Search workflows</label>
      <svg
        class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder={placeholder}
        aria-label="Search workflows"
        aria-describedby="search-no-results"
        class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-300 bg-white text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow duration-150 placeholder:text-slate-500"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
  </div>

  <!-- Row 2: Filters -->
  <div class="px-4 py-3 border-b border-slate-100">
    <div class="flex items-center gap-2 mb-2.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" /></svg>
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Filters</span>
      <button
        id="clear-filters"
        type="button"
        class="hidden ml-auto text-xs text-blue-600 hover:text-blue-800 font-medium transition-colors duration-150"
        aria-label="Clear all filters"
      >
        Clear all
      </button>
    </div>
    <div class="flex flex-wrap gap-2">
      {showOrgFilter && orgs.length > 0 && (
        <div class="relative">
          <label for="filter-org" class="sr-only">Filter by organization</label>
          <select id="filter-org" aria-label="Filter by organization" class={selectClass}>
            <option value="">All orgs</option>
            {orgs.map((o) => <option value={o}>{o}</option>)}
          </select>
          <Fragment set:html={chevron} />
        </div>
      )}

      {triggers.length > 0 && (
        <div class="relative">
          <label for="filter-trigger" class="sr-only">Filter by trigger</label>
          <select id="filter-trigger" aria-label="Filter by trigger" class={selectClass}>
            <option value="">All triggers</option>
            {triggers.map((t) => <option value={t}>{t}</option>)}
          </select>
          <Fragment set:html={chevron} />
        </div>
      )}

      {repos.length > 0 && (
        <div class="relative">
          <label for="filter-repo" class="sr-only">Filter by repository</label>
          <select
            id="filter-repo"
            aria-label="Filter by repository"
            data-all-repos={repos.join(',')}
            class={selectClass}
          >
            <option value="">All repos</option>
            {repos.map((r) => <option value={r}>{r}</option>)}
          </select>
          <Fragment set:html={chevron} />
        </div>
      )}

      {statuses.length > 0 && (
        <div class="relative">
          <label for="filter-status" class="sr-only">Filter by status</label>
          <select id="filter-status" aria-label="Filter by status" class={selectClass}>
            <option value="">All statuses</option>
            {statuses.map((s) => <option value={s}>{formatStatus(s)}</option>)}
          </select>
          <Fragment set:html={chevron} />
        </div>
      )}
    </div>
  </div>

  <!-- Row 3: Sort & display controls -->
  <div class="px-4 py-3 flex flex-wrap items-center gap-3">
    <span id="result-count" class="text-sm text-slate-500" aria-live="polite"></span>
    <div class="flex items-center gap-2 ml-auto">
      <div class="relative">
        <label for="sort-select" class="sr-only">Sort by</label>
        <select id="sort-select" aria-label="Sort by" class={selectClass}>
          <option value="name-asc">Sort: Name (A–Z)</option>
          <option value="name-desc">Sort: Name (Z–A)</option>
          <option value="status-asc">Sort: Status</option>
        </select>
        <Fragment set:html={chevron} />
      </div>
      {pageSize && (
        <div class="relative">
          <label for="per-page-select" class="sr-only">Items per page</label>
          <select id="per-page-select" aria-label="Items per page" class={selectClass}>
            {[10, 20, 30, 50, 100].map((n) => (
              <option value={n} selected={n === pageSize}>{n} per page</option>
            ))}
          </select>
          <Fragment set:html={chevron} />
        </div>
      )}
    </div>
  </div>

</div>

<div
  id="search-no-results"
  class="hidden text-center text-slate-500 py-12 text-sm"
  role="status"
  aria-live="polite"
  aria-atomic="true"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-slate-300" aria-hidden="true"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /><line x1="8" y1="11" x2="14" y2="11" /></svg>
  No results match your filters.
</div>

<script define:vars={{ reposByOrg, showOrgFilter, pageSize }}>
  const searchInput = document.getElementById('search-input');
  const orgSelect = document.getElementById('filter-org');
  const triggerSelect = document.getElementById('filter-trigger');
  const repoSelect = document.getElementById('filter-repo');
  const statusSelect = document.getElementById('filter-status');
  const perPageSelect = document.getElementById('per-page-select');
  const sortSelect = document.getElementById('sort-select');
  const noResults = document.getElementById('search-no-results');

  let currentPage = 1;
  let currentPageSize = pageSize;

  function pageRange(current, total) {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const pages = new Set([1, total, current]);
    for (let d = 1; d <= 2; d++) {
      if (current - d >= 1) pages.add(current - d);
      if (current + d <= total) pages.add(current + d);
    }
    const sorted = Array.from(pages).sort((a, b) => a - b);
    const result = [];
    let prev = 0;
    for (const p of sorted) {
      if (p - prev > 1) result.push(null);
      result.push(p);
      prev = p;
    }
    return result;
  }

  function renderPagination(total, totalPages) {
    const paginationEl = document.getElementById('pagination-controls');
    if (!paginationEl) return;
    if (!currentPageSize || totalPages <= 1) {
      paginationEl.innerHTML = '';
      return;
    }
    const start = (currentPage - 1) * currentPageSize + 1;
    const end = Math.min(currentPage * currentPageSize, total);
    const base = 'inline-flex items-center justify-center min-w-[2rem] px-2.5 py-1.5 text-sm rounded-lg font-medium transition-colors cursor-pointer select-none';
    const active = `${base} bg-blue-600 text-white shadow-sm`;
    const inactive = `${base} text-slate-600 hover:bg-slate-100 border border-slate-200`;
    const disabled = `${base} text-slate-300 border border-slate-200 cursor-not-allowed`;

    const pages = pageRange(currentPage, totalPages);

    function buildNav() {
      let btns = '';
      for (const p of pages) {
        if (p === null) {
          btns += `<span class="px-1 text-slate-400 select-none" aria-hidden="true">…</span>`;
        } else {
          btns += `<button class="pg-btn ${p === currentPage ? active : inactive}" data-page="${p}" ${p === currentPage ? 'aria-current="page"' : ''} aria-label="Page ${p}">${p}</button>`;
        }
      }
      return `
        <div class="flex items-center justify-end flex-wrap gap-3 py-4">
          <p class="text-sm text-slate-500">Showing <span class="font-medium text-slate-700">${start}–${end}</span> of <span class="font-medium text-slate-700">${total}</span> workflows</p>
          <nav class="flex items-center gap-1" aria-label="Workflow pagination" role="navigation">
            <button id="pg-prev-bottom" class="${currentPage === 1 ? disabled : inactive}" ${currentPage === 1 ? 'disabled aria-disabled="true"' : ''} aria-label="Previous page">‹ Prev</button>
            ${btns}
            <button id="pg-next-bottom" class="${currentPage === totalPages ? disabled : inactive}" ${currentPage === totalPages ? 'disabled aria-disabled="true"' : ''} aria-label="Next page">Next ›</button>
          </nav>
        </div>`;
    }

    paginationEl.innerHTML = buildNav('-bottom', 'Workflow pagination');

    function bindNav() {
      document.getElementById('pg-prev-bottom')?.addEventListener('click', () => {
        if (currentPage > 1) { currentPage--; applyFilters(); scrollToWorkflows(); }
      });
      document.getElementById('pg-next-bottom')?.addEventListener('click', () => {
        if (currentPage < totalPages) { currentPage++; applyFilters(); scrollToWorkflows(); }
      });
    }
    bindNav();

    document.querySelectorAll('.pg-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const p = parseInt(btn.dataset.page);
        if (p !== currentPage) { currentPage = p; applyFilters(); scrollToWorkflows(); }
      });
    });
  }

  function scrollToWorkflows() {
    const section = document.getElementById('all-workflows');
    if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function applyFilters() {
    const query = searchInput ? searchInput.value.trim().toLowerCase() : '';
    const selectedOrg = orgSelect ? orgSelect.value : '';
    const selectedTrigger = triggerSelect ? triggerSelect.value : '';
    const selectedRepo = repoSelect ? repoSelect.value : '';
    const selectedStatus = statusSelect ? statusSelect.value : '';

    // --- Workflow cards ---
    const matchingWorkflows = [];
    document.querySelectorAll('[data-search-text][data-triggers]').forEach((el) => {
      const searchText = (el.dataset.searchText ?? '').toLowerCase();
      const elOrg = el.dataset.org ?? '';
      const elRepo = el.dataset.repo ?? '';
      const elTriggers = (el.dataset.triggers ?? '').split(' ').filter(Boolean);
      const elStatus = el.dataset.status ?? 'unknown';

      const matches =
        (!query || searchText.includes(query)) &&
        (!selectedOrg || elOrg === selectedOrg) &&
        (!selectedTrigger || elTriggers.includes(selectedTrigger)) &&
        (!selectedRepo || elRepo === selectedRepo) &&
        (!selectedStatus || elStatus === selectedStatus);

      if (!matches) { el.style.display = 'none'; return; }
      matchingWorkflows.push(el);
    });

    if (sortSelect && matchingWorkflows.length > 0) {
      const [key, dir] = sortSelect.value.split('-');
      matchingWorkflows.sort((a, b) => {
        let valA, valB;
        if (key === 'status') {
          const statusOrder = { 'success': 1, 'in_progress': 2, 'queued': 3, 'failure': 4, 'cancelled': 5, 'skipped': 6, 'unknown': 7 };
          const statusA = (a.dataset.status || '').toLowerCase();
          const statusB = (b.dataset.status || '').toLowerCase();
          valA = statusOrder[statusA] || 99;
          valB = statusOrder[statusB] || 99;
        } else {
          valA = (a.dataset.name || '').toLowerCase();
          valB = (b.dataset.name || '').toLowerCase();
        }
        
        if (valA < valB) return dir === 'asc' ? -1 : 1;
        if (valA > valB) return dir === 'asc' ? 1 : -1;
        
        // Fallback to name for stability
        const nameA = (a.dataset.name || '').toLowerCase();
        const nameB = (b.dataset.name || '').toLowerCase();
        if (nameA < nameB) return -1;
        if (nameA > nameB) return 1;
        return 0;
      });

      // Reorder in DOM to maintain visual logic
      const parent = matchingWorkflows[0]?.parentElement;
      if (parent) {
        matchingWorkflows.forEach(el => parent.appendChild(el));
      }
    }

    if (currentPageSize && matchingWorkflows.length > 0) {
      const totalPages = Math.ceil(matchingWorkflows.length / currentPageSize);
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * currentPageSize;
      matchingWorkflows.forEach((el, i) => {
        el.style.display = (i >= start && i < start + currentPageSize) ? '' : 'none';
      });
      renderPagination(matchingWorkflows.length, totalPages);
    } else {
      matchingWorkflows.forEach((el) => (el.style.display = ''));
      renderPagination(0, 0);
    }

    if (noResults) noResults.classList.toggle('hidden', matchingWorkflows.length > 0);

    const resultCountEl = document.getElementById('result-count');
    if (resultCountEl) {
      const total = document.querySelectorAll('[data-search-text][data-triggers]').length;
      resultCountEl.textContent = matchingWorkflows.length === total
        ? `${total} workflow${total !== 1 ? 's' : ''}`
        : `${matchingWorkflows.length} of ${total} workflows`;
    }

    const clearBtn = document.getElementById('clear-filters');
    if (clearBtn) {
      const anyActive = [orgSelect, triggerSelect, repoSelect, statusSelect]
        .some(sel => sel && sel.value !== '');
      const searchActive = searchInput ? searchInput.value.trim() !== '' : false;
      clearBtn.classList.toggle('hidden', !anyActive && !searchActive);
    }
  }

  function updateRepoDropdown() {
    if (!repoSelect || !showOrgFilter || !orgSelect) return;
    const selectedOrg = orgSelect.value;
    const previousRepo = repoSelect.value;
    const allRepos = (repoSelect.dataset.allRepos ?? '').split(',').filter(Boolean);
    const nextRepos =
      selectedOrg && reposByOrg[selectedOrg] ? reposByOrg[selectedOrg] : allRepos;

    repoSelect.innerHTML = '<option value="">All repos</option>';
    nextRepos.forEach((repo) => {
      const opt = document.createElement('option');
      opt.value = repo;
      opt.textContent = repo;
      repoSelect.appendChild(opt);
    });

    if (nextRepos.includes(previousRepo)) {
      repoSelect.value = previousRepo;
    }
  }

  let debounceTimer;

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      currentPage = 1;
      debounceTimer = setTimeout(applyFilters, 150);
    });
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchInput.value) {
        searchInput.value = '';
        clearTimeout(debounceTimer);
        currentPage = 1;
        applyFilters();
      }
    });
  }

  if (orgSelect) {
    orgSelect.addEventListener('change', () => {
      currentPage = 1;
      updateRepoDropdown();
      applyFilters();
    });
  }

  if (triggerSelect) triggerSelect.addEventListener('change', () => { currentPage = 1; applyFilters(); });
  if (repoSelect) repoSelect.addEventListener('change', () => { currentPage = 1; applyFilters(); });
  if (statusSelect) statusSelect.addEventListener('change', () => { currentPage = 1; applyFilters(); });
  if (sortSelect) sortSelect.addEventListener('change', () => { currentPage = 1; applyFilters(); });
  if (perPageSelect) perPageSelect.addEventListener('change', () => {
    currentPageSize = parseInt(perPageSelect.value);
    currentPage = 1;
    applyFilters();
  });

  const clearFiltersBtn = document.getElementById('clear-filters');
  if (clearFiltersBtn) {
    clearFiltersBtn.addEventListener('click', () => {
      [orgSelect, triggerSelect, repoSelect, statusSelect].forEach(sel => {
        if (sel) sel.value = '';
      });
      if (searchInput) searchInput.value = '';
      currentPage = 1;
      if (showOrgFilter) updateRepoDropdown();
      applyFilters();
    });
  }

  // Run once the full DOM is ready so all workflow cards exist.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(applyFilters, 0));
  } else {
    setTimeout(applyFilters, 0);
  }
</script>
