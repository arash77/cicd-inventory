---
import Badge from './Badge.astro';

interface Job {
  job_id: string;
  name: string | null;
  runs_on: string | string[];
  steps_count: number;
  actions_used: { uses: string; name: string | null }[];
}

interface Props {
  org: string;
  repoName: string;
  repoUrl: string;
  workflowFile: string;
  workflowName: string;
  onTriggers: string[];
  jobs: Job[];
  statusBadgeUrl: string;
  detailHref: string;
  /** Text used for data-search-text filtering — pre-joined by caller */
  searchText: string;
}

const {
  org,
  repoName,
  repoUrl,
  workflowFile,
  workflowName,
  onTriggers,
  jobs,
  statusBadgeUrl,
  detailHref,
  searchText,
} = Astro.props;

const triggerColors: Record<string, string> = {
  push: 'bg-green-100 text-green-800',
  pull_request: 'bg-blue-100 text-blue-800',
  schedule: 'bg-yellow-100 text-yellow-800',
  workflow_dispatch: 'bg-purple-100 text-purple-800',
  release: 'bg-red-100 text-red-800',
};

const workflowGithubUrl = `${repoUrl}/actions/workflows/${workflowFile}`;
---

<article
  class="bg-white rounded-xl border border-gray-200 p-5 flex flex-col gap-3 hover:border-blue-300 hover:shadow-sm transition-all"
  data-search-text={searchText.toLowerCase()}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <a href={detailHref} class="font-semibold text-gray-900 hover:text-blue-700 truncate block">
        {workflowName}
      </a>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-gray-500 hover:text-blue-600"
      >
        {org}/{repoName}
      </a>
      <span class="text-xs text-gray-400 ml-2">{workflowFile}</span>
    </div>
    <Badge src={statusBadgeUrl} alt={`${workflowName} status`} workflowUrl={workflowGithubUrl} />
  </div>

  <!-- Triggers -->
  {onTriggers.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {onTriggers.map((t) => (
        <span
          class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${triggerColors[t] ?? 'bg-gray-100 text-gray-700'}`}
        >
          {t}
        </span>
      ))}
    </div>
  )}

  <!-- Jobs summary -->
  <div class="text-xs text-gray-500">
    {jobs.length} job{jobs.length !== 1 ? 's' : ''}
    {jobs.length > 0 && (
      <span class="ml-2 text-gray-400">
        ({jobs.map((j) => j.name ?? j.job_id).join(', ')})
      </span>
    )}
  </div>
</article>
