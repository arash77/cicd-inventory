---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';

export async function getStaticPaths() {
  const all = await getCollection('workflows');

  // Group by org/repo
  const grouped = all.reduce<Record<string, typeof all>>((acc, w) => {
    const key = `${w.data.org}/${w.data.repo_name}`;
    (acc[key] ??= []).push(w);
    return acc;
  }, {});

  return Object.entries(grouped).map(([key, workflows]) => {
    const [org, repo] = key.split('/');
    return {
      params: { org, repo },
      props: { workflows },
    };
  });
}

const { org, repo } = Astro.params;
const { workflows } = Astro.props;
const base = import.meta.env.BASE_URL;

const repoUrl = workflows[0]?.data.repo_url ?? `https://github.com/${org}/${repo}`;

const triggerColors: Record<string, string> = {
  push: 'bg-green-100 text-green-800',
  pull_request: 'bg-blue-100 text-blue-800',
  schedule: 'bg-yellow-100 text-yellow-800',
  workflow_dispatch: 'bg-purple-100 text-purple-800',
  release: 'bg-red-100 text-red-800',
};
---

<BaseLayout
  title={`${org}/${repo}`}
  description={`GitHub Actions workflows for ${org}/${repo}`}
>
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6">
    <a href={`${base}/`} class="hover:text-blue-600">Home</a>
    <span class="mx-1">/</span>
    <a href={`${base}/${org}/`} class="hover:text-blue-600">{org}</a>
    <span class="mx-1">/</span>
    <span class="text-gray-800 font-medium">{repo}</span>
  </nav>

  <!-- Repo header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-blue-700"
      >
        {org}/{repo}
      </a>
    </h1>
    <p class="text-gray-500 text-sm">
      {workflows.length} workflow{workflows.length !== 1 ? 's' : ''}
    </p>
  </div>

  <!-- Workflow details -->
  <div class="flex flex-col gap-8">
    {workflows.map((w) => {
      const workflowGithubUrl = `${repoUrl}/actions/workflows/${w.data.workflow_file}`;
      return (
        <section class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <!-- Workflow header -->
          <div class="flex items-start justify-between gap-4 p-6 border-b border-gray-100">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">{w.data.workflow_name}</h2>
              <a
                href={`${repoUrl}/blob/HEAD/${w.data.workflow_path}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-blue-600 hover:underline font-mono"
              >
                {w.data.workflow_path}
              </a>
            </div>
            <Badge
              src={w.data.status_badge_url}
              alt={`${w.data.workflow_name} status`}
              workflowUrl={workflowGithubUrl}
            />
          </div>

          <div class="p-6 flex flex-col gap-6">
            <!-- Triggers -->
            {w.data.on_triggers.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Triggers</h3>
                <div class="flex flex-wrap gap-2">
                  {w.data.on_triggers.map((t) => (
                    <span
                      class={`inline-block px-2.5 py-1 rounded-full text-xs font-medium ${triggerColors[t] ?? 'bg-gray-100 text-gray-700'}`}
                    >
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Jobs table -->
            {w.data.jobs.length > 0 && (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Jobs</h3>
                <div class="overflow-x-auto rounded-lg border border-gray-200">
                  <table class="min-w-full text-sm">
                    <thead class="bg-gray-50 border-b border-gray-200">
                      <tr>
                        <th class="text-left px-3 py-2 font-medium text-gray-600">Job</th>
                        <th class="text-left px-3 py-2 font-medium text-gray-600">Runs on</th>
                        <th class="text-right px-3 py-2 font-medium text-gray-600">Steps</th>
                        <th class="text-left px-3 py-2 font-medium text-gray-600">Actions used</th>
                      </tr>
                    </thead>
                    <tbody>
                      {w.data.jobs.map((job, i) => {
                        const runsOn = Array.isArray(job.runs_on)
                          ? job.runs_on.join(', ')
                          : job.runs_on;
                        return (
                          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                            <td class="px-3 py-2 font-medium text-gray-800">
                              {job.name ?? job.job_id}
                            </td>
                            <td class="px-3 py-2 font-mono text-xs text-gray-600">{runsOn}</td>
                            <td class="px-3 py-2 text-right text-gray-500">{job.steps_count}</td>
                            <td class="px-3 py-2">
                              <div class="flex flex-wrap gap-1">
                                {job.actions_used.map((a) => (
                                  <span class="inline-block bg-indigo-50 text-indigo-700 rounded px-1.5 py-0.5 text-xs font-mono">
                                    {a.uses}
                                  </span>
                                ))}
                              </div>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- Raw YAML -->
            <div>
              <details>
                <summary class="text-xs font-semibold uppercase tracking-wide text-gray-500 cursor-pointer select-none hover:text-gray-800 mb-2">
                  Raw YAML
                </summary>
                <pre class="yaml-block mt-2"><code>{w.data.raw_yaml}</code></pre>
              </details>
            </div>

            <!-- Meta -->
            <p class="text-xs text-gray-400">
              Last fetched: {w.data.last_fetched.toLocaleDateString('en-US', { dateStyle: 'medium' })}
            </p>
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
